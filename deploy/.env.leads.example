# 从企业微信群聊的“添加群机器人”中复制完整 Webhook 地址。
WECHAT_WORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=请替换

# 只允许官网页面发起带 Origin 的浏览器请求；多个域名用英文逗号分隔。
ALLOWED_ORIGINS=https://www.namche.cn,https://namche.cn

# 数据库保存在 Docker volume 中，不要改到静态网站目录。
LEADS_DB_PATH=/data/leads.db
PORT=8787
HOST=0.0.0.0

# 默认每个来源 IP 在 10 分钟内最多提交 5 次。
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=5

# 企业微信失败后自动重试，最多 12 次。
RETRY_INTERVAL_MS=60000
RETRY_BASE_MS=60000
MAX_NOTIFICATION_ATTEMPTS=12
WEBHOOK_TIMEOUT_MS=8000
